generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Rombel {
  id          String   @id @default(cuid())
  nama        String
  kelas       Int
  jurusan     String
  tahunajaran String   @map("tahunajaran")
  walikelas   String   @map("walikelas")
  siswa       Siswa[]
  createdat   DateTime @default(now()) @map("createdat")
  updatedat   DateTime @updatedAt @map("updatedat")

  @@map("rombel")
}

model Siswa {
  id            String   @id @default(cuid())
  nis           String   @unique
  nisn          String   @default("-")
  nama          String
  jeniskelamin  String   @map("jeniskelamin")
  tempatlahir   String   @default("-") @map("tempatlahir")
  tanggallahir  String   @default("-") @map("tanggallahir")
  rombelid      String   @map("rombelid")
  rombel        Rombel   @relation(fields: [rombelid], references: [id], onDelete: Cascade)
  nilai         Nilai[]
  eligible      Eligible?
  tka           TKA?
  createdat     DateTime @default(now()) @map("createdat")
  updatedat     DateTime @updatedAt @map("updatedat")

  @@map("siswa")
}

model Nilai {
  id             String   @id @default(cuid())
  siswaid        String   @map("siswaid")
  siswa          Siswa    @relation(fields: [siswaid], references: [id], onDelete: Cascade)
  matapelajaran  String   @map("matapelajaran")
  smt1           Float    @default(0)
  smt2           Float    @default(0)
  smt3           Float    @default(0)
  smt4           Float    @default(0)
  smt5           Float    @default(0)
  smt6           Float    @default(0)
  rerata         Float    @default(0)
  createdat      DateTime @default(now()) @map("createdat")
  updatedat      DateTime @updatedAt @map("updatedat")

  @@unique([siswaid, matapelajaran])
  @@map("nilai")
}

model Eligible {
  id         String   @id @default(cuid())
  siswaid    String   @unique @map("siswaid")
  siswa      Siswa    @relation(fields: [siswaid], references: [id], onDelete: Cascade)
  status     String
  keterangan String?
  createdat  DateTime @default(now()) @map("createdat")
  updatedat  DateTime @updatedAt @map("updatedat")

  @@map("eligible")
}

model TKA {
  id                 String   @id @default(cuid())
  siswaid            String   @unique @map("siswaid")
  siswa              Siswa    @relation(fields: [siswaid], references: [id], onDelete: Cascade)
  nomorpeserta       String   @default("-") @map("nomorpeserta")
  tanggalpelaksanaan String   @default("-") @map("tanggalpelaksanaan")
  bindonilai         Float    @default(0) @map("bindonilai")
  bindokategori      String   @default("-") @map("bindokategori")
  matnilai           Float    @default(0) @map("matnilai")
  matkategori        String   @default("-") @map("matkategori")
  bingnilai          Float    @default(0) @map("bingnilai")
  bingkategori       String   @default("-") @map("bingkategori")
  pilihan1nama       String   @default("-") @map("pilihan1nama")
  pilihan1nilai      Float    @default(0) @map("pilihan1nilai")
  pilihan1kategori   String   @default("-") @map("pilihan1kategori")
  pilihan2nama       String   @default("-") @map("pilihan2nama")
  pilihan2nilai      Float    @default(0) @map("pilihan2nilai")
  pilihan2kategori   String   @default("-") @map("pilihan2kategori")
  tkaid              String   @default("-") @map("tkaid")
  createdat          DateTime @default(now()) @map("createdat")
  updatedat          DateTime @updatedAt @map("updatedat")

  @@map("tka")
}
