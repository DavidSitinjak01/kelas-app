generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Rombel {
  id          String   @id @default(cuid())
  nama        String
  kelas       Int      // 10, 11, 12
  jurusan     String   // IPA, IPS, Bahasa, Umum
  tahunAjaran String
  waliKelas   String
  siswa       Siswa[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Siswa {
  id            String   @id @default(cuid())
  nis           String   @unique
  nisn          String   @default("-")
  nama          String
  jenisKelamin  String   // L, P
  tempatLahir   String   @default("-")
  tanggalLahir  String   @default("-")
  rombelId      String
  rombel        Rombel   @relation(fields: [rombelId], references: [id], onDelete: Cascade)
  nilai         Nilai[]
  eligible      Eligible?
  tka           TKA?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Nilai {
  id            String   @id @default(cuid())
  siswaId       String
  siswa         Siswa    @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  mataPelajaran String
  smt1          Float    @default(0)
  smt2          Float    @default(0)
  smt3          Float    @default(0)
  smt4          Float    @default(0)
  smt5          Float    @default(0)
  smt6          Float    @default(0)
  rerata        Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([siswaId, mataPelajaran])
}

model Eligible {
  id          String   @id @default(cuid())
  siswaId     String   @unique
  siswa       Siswa    @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  status      String   // eligible, tidak, bersyarat
  keterangan  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TKA {
  id                    String   @id @default(cuid())
  siswaId               String   @unique
  siswa                 Siswa    @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  nomorPeserta          String   @default("-")
  tanggalPelaksanaan    String   @default("-")
  // Mata Pelajaran Wajib
  bindoNilai            Float    @default(0)
  bindoKategori         String   @default("-")
  matNilai              Float    @default(0)
  matKategori           String   @default("-")
  bingNilai             Float    @default(0)
  bingKategori          String   @default("-")
  // Mata Pelajaran Pilihan (nama ditentukan per siswa)
  pilihan1Nama          String   @default("-")
  pilihan1Nilai         Float    @default(0)
  pilihan1Kategori      String   @default("-")
  pilihan2Nama          String   @default("-")
  pilihan2Nilai         Float    @default(0)
  pilihan2Kategori      String   @default("-")
  // Metadata
  tkaId                 String   @default("-")  // ID from PDF (e.g. TKA25-U2UVHL96R)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
